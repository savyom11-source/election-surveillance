# ============================================================
# ELECTION SURVEILLANCE PLATFORM — BACKEND ENV CONFIG
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database (PostgreSQL) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://election_user:Election@1234@localhost:5432/election_surveillance"

# ---- JWT ----
JWT_ACCESS_SECRET="change_this_to_a_long_random_string_access"
JWT_REFRESH_SECRET="change_this_to_a_long_random_string_refresh"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ---- AWS S3 (Recordings) ----
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="election-surveillance-recordings"

# ---- CORS ----
# Frontend URL allowed to call this API
CORS_ORIGIN="http://localhost:3000"

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
