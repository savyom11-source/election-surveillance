generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  STATE_ADMIN
  DISTRICT_OBSERVER
  OFFICE_OBSERVER
}

enum StreamType {
  RTMP
  RTSP
}

enum StreamStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RecordingStatus {
  AVAILABLE
  PROCESSING
  ARCHIVED
  DELETED
}

enum AuditAction {
  LOGIN
  LOGOUT
  VIEW_STREAM
  VIEW_RECORDING
  CREATE_USER
  UPDATE_USER
  DELETE_USER
  ASSIGN_ROLE
  CREATE_LOCATION
  UPDATE_LOCATION
  DELETE_LOCATION
  CREATE_CAMERA
  UPDATE_CAMERA
  DELETE_CAMERA
}

model State {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  districts  District[]
  userScopes UserScope[]
  @@map("states")
}

model District {
  id        String   @id @default(uuid())
  name      String
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stateId   String
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  offices    Office[]
  userScopes UserScope[]
  @@unique([stateId, code])
  @@map("districts")
}

model Office {
  id         String   @id @default(uuid())
  name       String
  address    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  districtId String
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  cameras    Camera[]
  userScopes UserScope[]
  @@map("offices")
}

model Camera {
  id          String       @id @default(uuid())
  name        String
  description String?
  streamUrl   String
  streamType  StreamType   @default(RTMP)
  status      StreamStatus @default(ACTIVE)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  officeId    String
  office      Office       @relation(fields: [officeId], references: [id], onDelete: Cascade)
  recordings  Recording[]
  auditLogs   AuditLog[]
  @@map("cameras")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(OFFICE_OBSERVER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String?
  createdBy    User?     @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers User[]    @relation("CreatedUsers")
  refreshTokens RefreshToken[]
  userScopes    UserScope[]
  auditLogs     AuditLog[]
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("refresh_tokens")
}

model UserScope {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stateId    String?
  state      State?    @relation(fields: [stateId], references: [id])
  districtId String?
  district   District? @relation(fields: [districtId], references: [id])
  officeId   String?
  office     Office?   @relation(fields: [officeId], references: [id])
  @@unique([userId, stateId])
  @@unique([userId, districtId])
  @@unique([userId, officeId])
  @@map("user_scopes")
}

model Recording {
  id          String          @id @default(uuid())
  s3Key       String          @unique
  s3Bucket    String
  filename    String
  durationSec Int?
  fileSizeMb  Float?
  status      RecordingStatus @default(AVAILABLE)
  recordedAt  DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  cameraId    String
  camera      Camera          @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  @@index([cameraId, recordedAt])
  @@map("recordings")
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  cameraId  String?
  camera    Camera?     @relation(fields: [cameraId], references: [id])
  @@index([userId, createdAt])
  @@index([cameraId, createdAt])
  @@map("audit_logs")
}
